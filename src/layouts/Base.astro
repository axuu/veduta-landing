---
import '../styles/global.css';
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
  title: string;
  description: string;
}

const { lang = 'en', title, description } = Astro.props;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-Hans' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a2622" />

    <link rel="alternate" hreflang="en" href={new URL('/', Astro.site)} />
    <link rel="alternate" hreflang="zh-Hans" href={new URL('/zh/', Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />

    <script>
      // Mark JS as available so reveal animations can opt in (content is visible without JS).
      document.documentElement.classList.add('js');

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const reveals = document.querySelectorAll('[data-reveal]');

      if (!prefersReduced && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-in');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );

        // Only arm (hide) elements that start below the fold; everything already
        // on screen stays visible from the first paint.
        const armLine = window.innerHeight * 0.92;
        for (const el of reveals) {
          if (el.getBoundingClientRect().top > armLine) {
            el.classList.add('reveal-armed');
            io.observe(el);
          }
        }

        // Failsafe: if the observer never fires (background tab, headless render),
        // reveal any still-armed element so the section never ships blank.
        window.setTimeout(() => {
          for (const el of document.querySelectorAll('[data-reveal].reveal-armed:not(.is-in)'))
            el.classList.add('is-in');
        }, 3000);
      }
    </script>
  </body>
</html>
