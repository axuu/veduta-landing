---
import { Image } from 'astro:assets';
import wallpaper from '../assets/art/church-heart-of-andes.jpg';
import { gallery } from '../data/artworks';
import { useTranslations, pick, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const church = gallery.find((a) => a.title.en === 'Heart of the Andes')!;
---

<section class="app">
  <div class="shell app__grid">
    <div class="app__copy" data-reveal>
      <h2 class="section-title">{t.app.title}</h2>
      <p class="app__lede label measure">{t.app.lede}</p>
      <ul class="app__specs">
        {
          t.app.specs.map((s) => (
            <li>
              <span class="app__tick" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="13" height="13">
                  <path d="M2.5 8.5l3.5 3.5 7.5-8.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span class="label">{s}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="app__shot-wrap" data-reveal style="--reveal-delay: 120ms">
      <div class="desktop" role="img" aria-label={t.app.shotAlt}>
        <Image src={wallpaper} alt="" widths={[700, 1100, 1500]} sizes="(max-width: 980px) 92vw, 52vw" class="desktop__wall" />
        <div class="desktop__tint" aria-hidden="true"></div>

        <div class="desktop__bar">
          <div class="desktop__bar-left">
            <span class="desktop__apple" aria-hidden="true"></span>
            <span class="desktop__menu-name is-dim">Finder</span>
            <span class="desktop__menu-name is-dim">File</span>
            <span class="desktop__menu-name is-dim">View</span>
          </div>
          <div class="desktop__bar-right">
            <span class="desktop__icon is-on" aria-hidden="true">
              <svg viewBox="0 0 20 20" width="13" height="13">
                <rect x="3.5" y="2.5" width="13" height="15" rx="0.8" fill="none" stroke="currentColor" stroke-width="1.3" />
                <path d="M5 14 L8.2 9 L10.4 11.6 L12.6 7.6 L15 14 Z" fill="currentColor" />
                <circle cx="12.4" cy="6.4" r="1.1" fill="currentColor" />
              </svg>
            </span>
            <span class="desktop__clock mono" aria-hidden="true">Tue 9:41</span>
          </div>
        </div>

        <div class="desktop__dropdown" aria-hidden="true">
          <div class="dd__now">
            <Image src={wallpaper} alt="" width={120} height={80} class="dd__thumb" />
            <span class="dd__text">
              <span class="dd__artist">{pick(church.artist, lang)}</span>
              <span class="dd__title">{pick(church.title, lang)}</span>
            </span>
          </div>
          <div class="dd__row"><span>{t.menu.next}</span><span class="dd__k mono">⌘N</span></div>
          <div class="dd__row"><span>{t.menu.shuffle}</span></div>
          <div class="dd__sep"></div>
          <div class="dd__row"><span>{t.menu.collection}</span><span class="dd__v">{t.app.collectionValue} ›</span></div>
          <div class="dd__row dd__row--toggle">
            <span>{t.menu.launch}</span>
            <span class="dd__switch"><span></span></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .app {
    padding-top: var(--space-section);
  }

  .app__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: clamp(2rem, 1rem + 5vw, 5rem);
    align-items: center;
  }

  .app__lede {
    margin-top: 1.3rem;
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .app__specs {
    list-style: none;
    padding: 0;
    margin-top: 2rem;
    display: grid;
    gap: 0.85rem;
  }
  .app__specs li {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--ink);
    font-size: var(--step-0);
  }
  .app__tick {
    flex: none;
    width: 22px;
    height: 22px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    color: var(--brass);
    border: 1px solid var(--brass-hairline);
  }

  /* ---- the desktop screenshot ---- */
  .desktop {
    position: relative;
    aspect-ratio: 16 / 10;
    border-radius: 12px;
    overflow: hidden;
    background: var(--wall-deep);
    box-shadow:
      0 0 0 1px var(--hairline-strong),
      0 1px 0 0 color-mix(in oklch, var(--ink) 14%, transparent) inset,
      0 50px 90px -40px rgba(0, 0, 0, 0.95),
      0 20px 40px -24px rgba(0, 0, 0, 0.8);
  }

  .desktop__wall {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .desktop__tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.28), transparent 18%);
  }

  .desktop__bar {
    position: absolute;
    inset: 0 0 auto 0;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: 12px;
    font-size: 0.7rem;
    background: color-mix(in oklch, var(--wall-deep) 60%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    color: var(--ink);
  }
  .desktop__bar-left,
  .desktop__bar-right {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .desktop__apple {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--ink);
    opacity: 0.85;
  }
  .desktop__menu-name {
    font-weight: 600;
  }
  .is-dim {
    opacity: 0.6;
    font-weight: 500;
  }
  .desktop__icon {
    display: grid;
    place-items: center;
    width: 22px;
    height: 18px;
    border-radius: 4px;
    color: var(--brass);
  }
  .desktop__icon.is-on {
    background: color-mix(in oklch, var(--brass) 24%, transparent);
  }
  .desktop__clock {
    font-size: 0.66rem;
  }

  .desktop__dropdown {
    position: absolute;
    top: 30px;
    right: 8px;
    width: min(62%, 260px);
    padding: 5px;
    border-radius: 10px;
    background: color-mix(in oklch, var(--wall-raised) 88%, transparent);
    backdrop-filter: saturate(1.4) blur(24px);
    -webkit-backdrop-filter: saturate(1.4) blur(24px);
    border: 1px solid var(--hairline-strong);
    box-shadow: 0 26px 50px -22px rgba(0, 0, 0, 0.8);
    font-size: 0.72rem;
    color: var(--ink-soft);
  }
  .dd__now {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 6px;
    margin-bottom: 3px;
    border-radius: 6px;
    background: color-mix(in oklch, var(--wall-deep) 55%, transparent);
  }
  .dd__thumb {
    width: 46px;
    height: 31px;
    object-fit: cover;
    border-radius: 2px;
    box-shadow: 0 0 0 1px var(--brass-hairline);
  }
  .dd__text {
    display: grid;
    gap: 1px;
    min-width: 0;
  }
  .dd__artist {
    font-weight: 600;
    color: var(--ink);
    font-size: 0.7rem;
  }
  .dd__title {
    font-family: var(--font-label);
    font-style: italic;
    color: var(--ink-mute);
    font-size: 0.7rem;
    line-height: 1.2;
  }
  .dd__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 5px 7px;
    border-radius: 5px;
  }
  .dd__row:first-of-type {
    background: var(--brass);
    color: var(--wall-deep);
  }
  .dd__row:first-of-type .dd__k {
    color: color-mix(in oklch, var(--wall-deep) 75%, var(--brass));
  }
  .dd__k,
  .dd__v {
    color: var(--ink-mute);
    font-size: 0.66rem;
  }
  .dd__sep {
    height: 1px;
    margin: 3px 7px;
    background: var(--hairline);
  }
  .dd__switch {
    width: 24px;
    height: 14px;
    border-radius: 999px;
    background: var(--brass);
    position: relative;
  }
  .dd__switch span {
    position: absolute;
    top: 2px;
    left: 12px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--wall-deep);
  }

  @media (max-width: 980px) {
    .app__grid {
      grid-template-columns: 1fr;
    }
    .app__shot-wrap {
      max-width: 38rem;
    }
  }
</style>
