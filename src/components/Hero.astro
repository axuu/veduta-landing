---
import { Image } from 'astro:assets';
import { hero } from '../data/artworks';
import { useTranslations, pick, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const brew = 'brew install --cask giraphant/tap/veduta';
const copied = lang === 'zh' ? '已复制到剪贴板' : 'Copied to clipboard';
const copyFail = lang === 'zh' ? '请按 ⌘C 复制' : 'Press ⌘C to copy';
---

<section class="hero" data-hero aria-label="Veduta on a macOS desktop">
  <div class="hero__stage">
    {
      hero.map((art, i) => (
        <figure
          class="hero__frame rot-item"
          data-rot={i}
          class:list={[{ 'is-active': i === 0 }]}
          style={`--tone:${art.tone}`}
        >
          <Image
            src={art.src}
            alt={pick(art.alt, lang)}
            sizes="100vw"
            widths={[768, 1280, 1920]}
            quality={60}
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : 'auto'}
            class="hero__img"
          />
        </figure>
      ))
    }
    <div class="hero__wash" aria-hidden="true"></div>
    <div class="hero__veil" aria-hidden="true"></div>
  </div>

  <div class="hero__grid shell">
    <div class="hero__content">
      <h1 class="hero__title">
        {t.hero.titleA}<br />{t.hero.titleB}
      </h1>
      <p class="hero__lede measure">{t.hero.lede}</p>

      <div class="hero__cta">
        <button
          class="cmd"
          type="button"
          data-copy={brew}
          data-copied={copied}
          data-copyfail={copyFail}
          aria-label={`${lang === 'zh' ? '复制' : 'Copy'}: ${brew}`}
        >
          <span class="cmd__prompt mono" aria-hidden="true">$</span>
          <span class="cmd__text mono">{brew}</span>
          <span class="cmd__icon" aria-hidden="true">
            <svg viewBox="0 0 20 20" width="16" height="16">
              <rect x="7" y="7" width="9" height="9" rx="1.6" fill="none" stroke="currentColor" stroke-width="1.4" />
              <path d="M13 7V5.4A1.4 1.4 0 0 0 11.6 4H5.4A1.4 1.4 0 0 0 4 5.4v6.2A1.4 1.4 0 0 0 5.4 13H7" fill="none" stroke="currentColor" stroke-width="1.4" />
            </svg>
          </span>
        </button>
        <a class="ghost-link" href="https://github.com/giraphant/veduta" rel="noopener">
          {t.hero.github}
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
            <path d="M4 12L12 4M6 4h6v6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
      <p class="hero__fine label">{t.hero.fine}</p>
    </div>

    <div class="hero__placard-wrap" aria-hidden="false">
      <span class="hero__rail-tag label">{t.hero.onView}</span>
      {
        hero.map((art, i) => (
          <figcaption
            class="hero__placard rot-item"
            data-rot={i}
            class:list={[{ 'is-active': i === 0 }]}
          >
            <span class="hero__placard-artist">{pick(art.artist, lang)}</span>
            <span class="hero__placard-title">{pick(art.title, lang)}</span>
            <span class="hero__placard-meta mono">
              {pick(art.date, lang)} &middot; {pick(art.source, lang)} &middot; {t.hero.openAccess}
            </span>
          </figcaption>
        ))
      }
    </div>
  </div>

  <a class="hero__scroll" href="#what" aria-label={t.hero.readOn}>
    <span class="label">{t.hero.readOn}</span>
    <svg viewBox="0 0 12 18" width="12" height="18" aria-hidden="true">
      <path d="M6 1v15M1.5 11.5L6 16l4.5-4.5" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</section>

<script>
  const stage = document.querySelector<HTMLElement>('[data-hero]');
  const items = Array.from(document.querySelectorAll<HTMLElement>('.rot-item'));
  const frames = items.filter((el) => el.classList.contains('hero__frame'));
  const count = frames.length;

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // "Gallery lights up" on load.
  requestAnimationFrame(() => stage?.classList.add('is-lit'));

  if (stage && count > 1 && !prefersReduced) {
    let current = 0;
    let timer = 0;

    const show = (n: number) => {
      current = (n + count) % count;
      for (const el of items) {
        const idx = Number(el.dataset.rot);
        el.classList.toggle('is-active', idx === current);
      }
    };
    const tick = () => show(current + 1);

    const start = () => {
      stop();
      timer = window.setInterval(tick, 7000);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
      timer = 0;
    };

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });

    start();
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: clamp(560px, 92svh, 1000px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__stage {
    position: absolute;
    inset: 0;
    z-index: -2;
    background: var(--wall-deep);
  }

  .hero__frame {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    transition: opacity 1.6s var(--ease-out-quint);
    will-change: opacity;
  }
  .hero__frame.is-active {
    opacity: 1;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    transform: scale(1.06);
  }

  /* slow Ken Burns only on the active frame */
  @media (prefers-reduced-motion: no-preference) {
    .hero__frame.is-active .hero__img {
      transform: scale(1.005);
      transition: transform 8s linear;
    }
  }

  .hero__wash {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 80% at 70% 20%, transparent 40%, rgba(0, 0, 0, 0.32) 100%),
      linear-gradient(
        to top,
        var(--wall) 2%,
        color-mix(in oklch, var(--wall) 72%, transparent) 24%,
        transparent 52%
      ),
      linear-gradient(105deg, rgba(0, 0, 0, 0.55) 0%, transparent 46%);
  }

  /* the gallery-lights veil that lifts on load */
  .hero__veil {
    position: absolute;
    inset: 0;
    background: var(--wall-deep);
    opacity: 0.85;
    transition: opacity 1.8s var(--ease-out-expo);
  }
  .hero.is-lit .hero__veil {
    opacity: 0;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 2rem;
    width: 100%;
    padding-bottom: clamp(2.5rem, 1.5rem + 4vw, 5rem);
    padding-top: 6rem;
  }

  .hero__content {
    max-width: 40rem;
  }

  /* staged entrance after the lights come up (only when JS can complete it) */
  :global(.js) .hero__title,
  :global(.js) .hero__lede,
  :global(.js) .hero__cta,
  :global(.js) .hero__fine,
  :global(.js) .hero__placard-wrap {
    opacity: 0;
    transform: translateY(20px);
  }
  .hero.is-lit .hero__title,
  .hero.is-lit .hero__lede,
  .hero.is-lit .hero__cta,
  .hero.is-lit .hero__fine,
  .hero.is-lit .hero__placard-wrap {
    opacity: 1;
    transform: none;
    transition:
      opacity 0.9s var(--ease-out-quint),
      transform 0.9s var(--ease-out-quint);
  }
  .hero.is-lit .hero__lede {
    transition-delay: 0.12s;
  }
  .hero.is-lit .hero__cta {
    transition-delay: 0.22s;
  }
  .hero.is-lit .hero__fine {
    transition-delay: 0.3s;
  }
  .hero.is-lit .hero__placard-wrap {
    transition-delay: 0.42s;
  }

  .hero__title {
    font-size: var(--step-5);
    font-weight: 800;
    letter-spacing: -0.034em;
    line-height: 0.98;
    color: var(--ink);
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.5);
  }

  .hero__lede {
    margin-top: 1.4rem;
    font-size: var(--step-1);
    line-height: 1.55;
    color: var(--ink);
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.55);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.4rem;
    margin-top: 2rem;
  }

  .cmd {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.85rem 1.05rem;
    border-radius: 8px;
    background: color-mix(in oklch, var(--wall-deep) 80%, transparent);
    border: 1px solid var(--brass-hairline);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--ink);
    box-shadow: 0 12px 30px -18px rgba(0, 0, 0, 0.9);
    transition:
      border-color 0.2s,
      transform 0.2s var(--ease-out-quint),
      background 0.2s;
  }
  .cmd:hover {
    border-color: var(--brass);
    transform: translateY(-1px);
    background: color-mix(in oklch, var(--wall-deep) 88%, transparent);
  }
  .cmd__prompt {
    color: var(--brass);
  }
  .cmd__text {
    font-size: 0.92rem;
    letter-spacing: -0.01em;
  }
  .cmd__icon {
    color: var(--ink-mute);
    display: grid;
    place-items: center;
    transition: color 0.2s;
  }
  .cmd:hover .cmd__icon {
    color: var(--brass);
  }
  .cmd.is-copied .cmd__icon {
    color: var(--brass-bright);
  }

  .ghost-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    color: var(--ink);
    padding-bottom: 2px;
    border-bottom: 1px solid var(--brass-hairline);
    transition: border-color 0.2s, gap 0.2s var(--ease-out-quint);
  }
  .ghost-link:hover {
    border-color: var(--brass);
    gap: 0.6rem;
  }

  .hero__fine {
    margin-top: 1.3rem;
    font-style: italic;
    font-size: var(--step--1);
    color: var(--ink-soft);
  }

  /* ---- placard, museum label beside the art ---- */
  .hero__placard-wrap {
    position: relative;
    display: grid;
    justify-items: end;
    text-align: right;
    padding-left: 2.2rem;
    min-width: 14rem;
    min-height: 6.5rem;
  }

  .hero__rail-tag {
    font-style: italic;
    font-size: var(--step--1);
    color: var(--brass);
    margin-bottom: 0.7rem;
    padding-right: 0.1rem;
  }
  .hero__rail-tag::before {
    content: '';
    display: inline-block;
    width: 1.6rem;
    height: 1px;
    vertical-align: middle;
    margin-right: 0.6rem;
    background: var(--brass);
  }

  .hero__placard {
    grid-area: 2 / 1;
    display: grid;
    gap: 0.2rem;
    justify-items: end;
    opacity: 0;
    transition: opacity 1.6s var(--ease-out-quint);
  }
  .hero__placard.is-active {
    opacity: 1;
  }
  .hero__placard-artist {
    font-weight: 600;
    font-size: var(--step-1);
    color: var(--ink);
    letter-spacing: -0.015em;
  }
  .hero__placard-title {
    font-family: var(--font-label);
    font-style: italic;
    font-size: var(--step-0);
    line-height: 1.3;
    color: var(--ink-soft);
    max-width: 18rem;
  }
  .hero__placard-meta {
    font-size: 0.72rem;
    color: var(--ink-mute);
    margin-top: 0.25rem;
    letter-spacing: 0.01em;
  }

  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: 1.1rem;
    transform: translateX(-50%);
    display: grid;
    justify-items: center;
    gap: 0.45rem;
    color: var(--ink-mute);
    font-style: italic;
    font-size: 0.78rem;
    transition: color 0.2s;
  }
  .hero__scroll:hover {
    color: var(--brass);
  }
  .hero__scroll svg {
    animation: nudge 2.4s var(--ease-out-quint) infinite;
  }
  @keyframes nudge {
    0%, 60%, 100% {
      transform: translateY(0);
    }
    80% {
      transform: translateY(4px);
    }
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 2.5rem;
    }
    .hero__placard-wrap {
      justify-items: start;
      text-align: left;
      padding-left: 0;
    }
    .hero__rail-tag::before {
      display: none;
    }
    .hero__placard {
      justify-items: start;
    }
    .hero__placard-title {
      max-width: none;
    }
    .hero__scroll {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__frame,
    .hero__placard,
    .hero__veil {
      transition: none;
    }
    .hero__img {
      transform: scale(1.02);
    }
    .hero__title,
    .hero__lede,
    .hero__cta,
    .hero__fine,
    .hero__placard-wrap {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .hero__scroll svg {
      animation: none;
    }
  }
</style>
