---
import { Image } from 'astro:assets';
import detail from '../assets/art/canaletto-piazza-san-marco.jpg';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const capAlt =
  lang === 'zh'
    ? '卡纳莱托《圣马可广场》局部，大教堂沐浴在晨光的暖意中。'
    : "A detail of Canaletto's Piazza San Marco, the basilica warm in morning light.";
---

<section class="etym">
  <div class="shell etym__grid">
    <div class="etym__text" data-reveal>
      <p class="etym__word">
        <span class="etym__term">{t.etym.term}</span>
        <span class="etym__pron mono">{t.etym.pron}</span>
        <span class="etym__pos">{t.etym.pos}</span>
      </p>
      <p class="etym__def">{t.etym.def}</p>
      <p class="etym__cn">淡景 &middot; <span class="etym__cn-gloss">{t.etym.cnGloss}</span></p>
      <p class="etym__close">{t.etym.close}</p>
    </div>

    <figure class="etym__plate" data-reveal style="--reveal-delay: 120ms">
      <div class="frame frame--tall">
        <Image
          src={detail}
          alt={capAlt}
          widths={[420, 680, 960]}
          sizes="(max-width: 880px) 70vw, 34vw"
          class="frame__img"
        />
      </div>
      <figcaption class="etym__cap label">
        {t.etym.capArtist}, <span class="etym__cap-i">{t.etym.capTitle}</span>, {t.etym.capDate}
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .etym {
    padding-top: var(--space-section);
  }

  .etym__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(2.5rem, 1rem + 6vw, 6rem);
  }

  .etym__text {
    max-width: 40rem;
  }

  .etym__word {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem 1.1rem;
    margin-bottom: 1.6rem;
  }
  .etym__term {
    font-family: var(--font-label);
    font-style: italic;
    font-size: var(--step-4);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1;
  }
  .etym__pron {
    font-size: var(--step-0);
    color: var(--brass);
  }
  .etym__pos {
    font-family: var(--font-label);
    font-style: italic;
    font-size: var(--step-0);
    color: var(--ink-mute);
  }

  .etym__def {
    font-family: var(--font-label);
    font-size: var(--step-2);
    line-height: 1.5;
    font-weight: 300;
    color: var(--ink);
    text-wrap: pretty;
  }

  .etym__cn {
    margin-top: 1.6rem;
    font-size: var(--step-2);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--brass);
  }
  .etym__cn-gloss {
    font-family: var(--font-label);
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0;
    color: var(--ink-soft);
    font-size: 0.78em;
  }

  .etym__close {
    margin-top: 1.8rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--hairline);
    font-size: var(--step-1);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 46ch;
  }

  .etym__cap {
    margin-top: 1rem;
    font-style: italic;
    font-size: var(--step--1);
    color: var(--ink-mute);
    text-align: center;
  }
  .etym__cap-i {
    color: var(--ink-soft);
  }

  @media (max-width: 880px) {
    .etym__grid {
      grid-template-columns: 1fr;
    }
    .etym__plate {
      max-width: 22rem;
    }
    .etym__cap {
      text-align: left;
    }
  }
</style>
