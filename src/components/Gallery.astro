---
import { Image } from 'astro:assets';
import { gallery } from '../data/artworks';
import { useTranslations, pick, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="library" id="library">
  <div class="shell">
    <div class="library__head">
      <h2 class="section-title" data-reveal>{t.gallery.title}</h2>
      <p class="library__lede label measure" data-reveal style="--reveal-delay: 80ms">
        {t.gallery.lede}
      </p>
    </div>

    <div class="rail rail--full"></div>

    <div class="hang">
      {
        gallery.map((art, i) => (
          <figure class="piece" data-reveal style={`--reveal-delay: ${(i % 3) * 90}ms`}>
            <div class="piece__frame frame">
              <Image
                src={art.src}
                alt={pick(art.alt, lang)}
                widths={[360, 560, 800]}
                sizes="(max-width: 620px) 88vw, (max-width: 980px) 44vw, 30vw"
                class="frame__img"
              />
            </div>
            <figcaption class="piece__label">
              <span class="piece__artist">{pick(art.artist, lang)}</span>
              <span class="piece__title">{pick(art.title, lang)}</span>
              <span class="piece__meta mono">{pick(art.date, lang)} &middot; {pick(art.source, lang)}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .library {
    padding-top: var(--space-section);
  }

  .library__head {
    display: grid;
    gap: 1rem;
    max-width: 52rem;
  }
  .library__lede {
    font-size: var(--step-1);
    color: var(--ink-soft);
    line-height: 1.55;
  }

  /* salon hang: masonry that respects each painting's real proportions */
  .hang {
    columns: 3;
    column-gap: clamp(1.4rem, 0.8rem + 2.4vw, 3rem);
  }

  .piece {
    break-inside: avoid;
    margin: 0 0 clamp(2.2rem, 1.4rem + 2.5vw, 3.6rem);
  }

  .piece__frame {
    transition:
      transform 0.5s var(--ease-out-quint),
      box-shadow 0.5s var(--ease-out-quint),
      filter 0.5s var(--ease-out-quint);
    filter: brightness(0.94);
  }
  .piece:hover .piece__frame {
    transform: translateY(-5px);
    filter: brightness(1.06);
    box-shadow:
      0 1px 0 0 var(--brass-bright) inset,
      0 40px 70px -30px rgba(0, 0, 0, 0.95),
      0 0 38px -10px color-mix(in oklch, var(--brass) 40%, transparent);
  }

  .piece__label {
    display: grid;
    gap: 0.16rem;
    margin-top: 0.95rem;
    padding-left: 0.1rem;
    transition: transform 0.4s var(--ease-out-quint);
  }
  .piece:hover .piece__label {
    transform: translateX(3px);
  }
  .piece__artist {
    font-weight: 600;
    color: var(--ink);
    font-size: var(--step-0);
    letter-spacing: -0.01em;
  }
  .piece__title {
    font-family: var(--font-label);
    font-style: italic;
    color: var(--ink-soft);
    font-size: var(--step-0);
    line-height: 1.3;
  }
  .piece__meta {
    font-size: 0.72rem;
    color: var(--ink-mute);
    margin-top: 0.28rem;
    letter-spacing: 0.01em;
  }

  @media (max-width: 980px) {
    .hang {
      columns: 2;
    }
  }
  @media (max-width: 620px) {
    .hang {
      columns: 1;
      max-width: 30rem;
      margin-inline: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .piece__frame,
    .piece__label {
      transition: none;
    }
  }
</style>
