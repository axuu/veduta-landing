---
const brew = 'brew install --cask giraphant/tap/veduta';
const repo = 'https://github.com/giraphant/veduta';
---

<section class="get" id="get">
  <div class="shell">
    <div class="get__panel" data-reveal>
      <h2 class="get__title">Bring the view home.</h2>
      <p class="get__sub label">One command. No account. macOS 13 and up.</p>

      <div class="get__cta">
        <button class="cmd cmd--lg" type="button" data-copy={brew} aria-label={`Copy: ${brew}`}>
          <span class="cmd__prompt mono" aria-hidden="true">$</span>
          <span class="cmd__text mono">{brew}</span>
          <span class="cmd__icon" aria-hidden="true">
            <svg viewBox="0 0 20 20" width="17" height="17">
              <rect x="7" y="7" width="9" height="9" rx="1.6" fill="none" stroke="currentColor" stroke-width="1.4" />
              <path d="M13 7V5.4A1.4 1.4 0 0 0 11.6 4H5.4A1.4 1.4 0 0 0 4 5.4v6.2A1.4 1.4 0 0 0 5.4 13H7" fill="none" stroke="currentColor" stroke-width="1.4" />
            </svg>
          </span>
        </button>
        <a class="ghost-link" href={repo} rel="noopener">
          View on GitHub
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
            <path d="M4 12L12 4M6 4h6v6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="rail"></div>

  <footer class="foot">
    <div class="shell foot__grid">
      <div class="foot__brand">
        <span class="foot__word">
          Veduta <span class="foot__cn">淡景</span>
        </span>
        <p class="foot__tag label">
          A local-first macOS wallpaper app for public-domain and museum artwork.
        </p>
        <p class="foot__credit label">
          Artwork shown: Open Access, The Metropolitan Museum of Art (CC0).
        </p>
      </div>

      <nav class="foot__cols" aria-label="Footer">
        <div class="foot__col">
          <span class="foot__col-h">Project</span>
          <a href="https://github.com/giraphant/veduta" rel="noopener">GitHub</a>
          <a href="https://github.com/giraphant/veduta/releases" rel="noopener">Releases</a>
          <a href="https://github.com/giraphant/veduta#readme" rel="noopener">Read me</a>
        </div>
        <div class="foot__col">
          <span class="foot__col-h">Provenance</span>
          <a href="https://www.metmuseum.org/about-the-met/policies-and-documents/open-access" rel="noopener">Open Access</a>
          <a href="https://creativecommons.org/publicdomain/zero/1.0/" rel="noopener">CC0 / Public domain</a>
        </div>
      </nav>
    </div>

    <div class="shell foot__base">
      <span class="label">Built local-first. The art belongs to everyone.</span>
      <span class="label foot__colophon">
        Schibsted Grotesk &middot; Spectral &middot; Spline Sans Mono
      </span>
    </div>
  </footer>
</section>

<div class="toast" data-toast role="status" aria-live="polite"></div>

<style>
  .get {
    padding-top: var(--space-section);
  }

  .get__panel {
    position: relative;
    text-align: center;
    padding: clamp(3rem, 2rem + 5vw, 6rem) var(--gutter);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(120% 140% at 50% 0%, color-mix(in oklch, var(--brass) 9%, transparent), transparent 60%),
      var(--wall-deep);
    border: 1px solid var(--brass-hairline);
    overflow: hidden;
  }
  .get__panel::before {
    content: '';
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: 1px;
    background: var(--frame-grad);
  }

  .get__title {
    font-size: var(--step-4);
    font-weight: 800;
    letter-spacing: -0.032em;
    color: var(--ink);
  }
  .get__sub {
    margin-top: 0.9rem;
    font-style: italic;
    font-size: var(--step-1);
    color: var(--ink-soft);
  }

  .get__cta {
    margin-top: 2.2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem 1.6rem;
  }

  .cmd--lg {
    padding: 1rem 1.3rem;
  }
  .cmd--lg .cmd__text {
    font-size: clamp(0.82rem, 0.7rem + 0.6vw, 1rem);
  }

  /* footer */
  .foot {
    padding-bottom: clamp(2.5rem, 1.5rem + 3vw, 4rem);
  }
  .foot__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
    gap: clamp(2rem, 1rem + 4vw, 5rem);
    padding-block: clamp(1rem, 0.5rem + 2vw, 2.5rem);
  }
  .foot__word {
    font-size: var(--step-2);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .foot__cn {
    color: var(--brass);
    font-size: 0.7em;
    letter-spacing: 0.08em;
    margin-left: 0.2em;
  }
  .foot__tag {
    margin-top: 0.9rem;
    font-style: italic;
    font-size: var(--step-0);
    color: var(--ink-soft);
    max-width: 40ch;
  }
  .foot__credit {
    margin-top: 0.8rem;
    font-size: var(--step--1);
    color: var(--ink-mute);
  }

  .foot__cols {
    display: flex;
    gap: clamp(2rem, 1rem + 4vw, 4rem);
  }
  .foot__col {
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }
  .foot__col-h {
    font-family: var(--font-label);
    font-style: italic;
    font-size: var(--step--1);
    color: var(--brass);
    margin-bottom: 0.2rem;
  }
  .foot__col a {
    color: var(--ink-soft);
    font-size: var(--step-0);
    width: fit-content;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .foot__col a:hover {
    color: var(--ink);
    border-color: var(--brass);
  }

  .foot__base {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.6rem 2rem;
    padding-top: clamp(1.5rem, 1rem + 2vw, 2.5rem);
    border-top: 1px solid var(--hairline);
    font-size: var(--step--1);
    color: var(--ink-mute);
    font-style: italic;
  }
  .foot__colophon {
    color: var(--ink-mute);
  }

  /* toast */
  .toast {
    position: fixed;
    left: 50%;
    bottom: 2rem;
    transform: translate(-50%, 140%);
    z-index: var(--z-toast);
    padding: 0.7rem 1.1rem;
    border-radius: 999px;
    background: var(--brass);
    color: var(--wall-deep);
    font-weight: 600;
    font-size: 0.85rem;
    box-shadow: 0 18px 40px -16px rgba(0, 0, 0, 0.8);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 0.5s var(--ease-out-expo),
      opacity 0.4s var(--ease-out-quint);
  }
  .toast.is-shown {
    transform: translate(-50%, 0);
    opacity: 1;
  }

  @media (max-width: 700px) {
    .foot__grid {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .toast {
      transition: opacity 0.2s;
      transform: translate(-50%, 0);
    }
  }
</style>
