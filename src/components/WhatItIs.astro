---
import { Image } from 'astro:assets';
import canaletto from '../assets/art/canaletto-grand-canal-rialto.jpg';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const plateAlt =
  lang === 'zh'
    ? "卡纳莱托《大运河》局部：宫邸立面与贡多拉倒映在平静的水面上。"
    : "A detail of Canaletto's Grand Canal: palace facades and gondolas mirrored in still water.";
---

<section class="what" id="what">
  <div class="shell what__grid">
    <figure class="what__plate" data-reveal>
      <div class="frame">
        <Image
          src={canaletto}
          alt={plateAlt}
          widths={[480, 760, 1100]}
          sizes="(max-width: 880px) 90vw, 44vw"
          class="frame__img"
        />
      </div>
      <figcaption class="what__plate-cap label" set:html={t.what.cap} />
    </figure>

    <div class="what__copy" data-reveal style="--reveal-delay: 90ms">
      <h2 class="section-title what__title">{t.what.title}</h2>
      <p class="what__body label measure" set:html={t.what.body} />
      <ul class="what__list">
        {
          t.what.items.map((item) => (
            <li>
              <span class="what__k">{item.k}</span>
              <span class="what__v label">{item.v}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .what {
    padding-top: var(--space-section);
  }

  .what__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1fr);
    align-items: center;
    gap: clamp(2rem, 1rem + 5vw, 5rem);
  }

  .what__plate {
    margin: 0;
  }

  .what__plate-cap {
    margin-top: 1.1rem;
    font-style: italic;
    font-size: var(--step--1);
    color: var(--ink-mute);
  }

  .what__title {
    max-width: 18ch;
  }

  .what__body {
    margin-top: 1.4rem;
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .what__list {
    list-style: none;
    padding: 0;
    margin-top: 2.2rem;
    display: grid;
    gap: 1.1rem;
  }
  .what__list li {
    display: grid;
    gap: 0.15rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--hairline);
  }
  .what__k {
    font-weight: 600;
    color: var(--ink);
    font-size: var(--step-0);
  }
  .what__v {
    color: var(--ink-mute);
    font-size: var(--step-0);
    line-height: 1.5;
  }
  /* the path is injected via set:html, so pierce the scope to reach it */
  .what__body :global(.mono),
  .what__plate-cap :global(.mono) {
    color: var(--brass);
  }

  @media (max-width: 880px) {
    .what__grid {
      grid-template-columns: 1fr;
    }
    .what__plate {
      max-width: 32rem;
    }
  }
</style>
